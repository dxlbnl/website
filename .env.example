# Neon Postgres — get from Vercel dashboard → Storage → your database → .env.local
DATABASE_URL=

# Admin token — generate with: openssl rand -hex 32
ADMIN_TOKEN=

# Stripe — get from dashboard.stripe.com/test/apikeys and dashboard.stripe.com/test/webhooks
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Resend — get API key from resend.com/api-keys
RESEND_API_KEY=re_
# Segment ID — create a segment at resend.com/segments (or migrate from an existing audience), paste the UUID here
RESEND_SEGMENT_ID=
# Verified sending domain configured at resend.com/domains
RESEND_FROM=Dexter <hello@yourdomain.com>
# Webhook signing secret — create a webhook at resend.com/webhooks pointing to /api/resend-webhook, subscribe to email.opened
RESEND_WEBHOOK_SECRET=
